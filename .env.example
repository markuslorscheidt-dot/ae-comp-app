# --- Google Drive (Service Account, readonly) ---
# Einmal konfigurieren; wird von mehreren ZIP-Imports genutzt (u. a. Up-/Downsells, Phorest Pay, SMS, …).
GOOGLE_DRIVE_SERVICE_ACCOUNT_EMAIL=
# Private Key aus der JSON-Key-Datei; Zeilenumbrüche als \n escapen (in Anführungszeichen).
GOOGLE_DRIVE_PRIVATE_KEY=

# --- Up-/Downsells (Looker-ZIP aus Ordner) ---
# Ordner-ID aus der URL: https://drive.google.com/drive/u/0/folders/<DIESE_ID>
GOOGLE_DRIVE_UP_DOWNSELLS_FOLDER_ID=1v9pAJ_vC2Fch6Og2705LXRsIW7HtwsCb

# --- DACH Client Numbers (ZIP aus Ordner, Default ist im Code hinterlegt) ---
GOOGLE_DRIVE_DACH_CLIENT_NUMBERS_FOLDER_ID=1bCh2alo1X7a7XlgCXPhebBknkEI1coi5

# --- Marketing Cost (ZIP aus Ordner, Default ist im Code hinterlegt) ---
GOOGLE_DRIVE_MARKETING_COSTS_FOLDER_ID=18vqkJDffpi0X6ad-BTzRECEEVJ1c1n9s

# Optional: weiterhin für andere Features (siehe Projekt-Doku)
# NEXT_PUBLIC_SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# CRON_SECRET=
